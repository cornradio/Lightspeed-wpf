<Window x:Class="Lightspeed_wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lightspeed" 
        Height="600" Width="500"
        Background="#1E1E1E"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="FolderButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5D5D5D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SideButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5D5D5D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#505050"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="5,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border Background="{TemplateBinding Background}" 
                                BorderThickness="0" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D2D2D"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3D3D3D"/>
                </Trigger>
                <DataTrigger Binding="{Binding JustOpened}" Value="True">
                    <Setter Property="Background" Value="#2E7D32"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#1E1E1E"/>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="#1E1E1E"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D2D2D" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="Btn0" Content="0" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn1" Content="1" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn2" Content="2" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn3" Content="3" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn4" Content="4" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn5" Content="5" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn6" Content="6" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn7" Content="7" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn8" Content="8" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn9" Content="9" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <ListView x:Name="FileListView" 
                      Background="#1E1E1E" 
                      Foreground="White"
                      BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      MouseDoubleClick="FileListView_MouseDoubleClick"
                      MouseRightButtonDown="FileListView_MouseRightClick">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="5"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderThickness="0" 
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D2D2D"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#3D3D3D"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="{Binding RowMargin}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0" Source="{Binding Icon}" Width="{Binding IconSize}" Height="{Binding IconSize}" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" Foreground="White"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Border x:Name="SettingsPanel" 
                    Background="#2D2D2D" 
                    Visibility="Collapsed"
                    Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#2D2D2D">
                    <StackPanel>
                        <TextBlock Text="设置" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                        <TextBlock Text="AHK 功能" Foreground="#888888" FontSize="12" Margin="0,0,0,10"/>
                        <Button Content="📁 创建文件夹" Style="{StaticResource SettingsButtonStyle}" Click="BtnCreateFolders_Click"/>
                        <Button Content="⚙ 生成 AHK 脚本" Style="{StaticResource SettingsButtonStyle}" Click="BtnGenerateAHK_Click"/>
                        <Button Content="▶ 启动 AHK" Style="{StaticResource SettingsButtonStyle}" Click="BtnStartAHK_Click"/>
                        <Button Content="🚀 生成 + 启动" Style="{StaticResource SettingsButtonStyle}" Click="BtnGenerateAndStart_Click"/>
                        
                        <CheckBox x:Name="ChkAutoStartAHK" Content="AHK 自启动" Foreground="White" Margin="0,10,0,5"/>

                        <Separator Background="#3D3D3D" Margin="0,15"/>

                        <TextBlock Text="文件夹操作" Foreground="#888888" FontSize="12" Margin="0,0,0,10"/>
                        <Button Content="📂 在资源管理器中打开" Style="{StaticResource SettingsButtonStyle}" Click="BtnOpenInExplorer_Click"/>

                        <Separator Background="#3D3D3D" Margin="0,15"/>

                        <TextBlock Text="显示设置" Foreground="#888888" FontSize="12" Margin="0,0,0,10"/>
                        
                        <TextBlock Text="图标大小" Foreground="White" Margin="0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <Slider x:Name="SliderIconSize" Width="200" Minimum="16" Maximum="64" Value="32" ValueChanged="SliderIconSize_ValueChanged"/>
                            <TextBlock x:Name="TxtIconSize" Text="32" Foreground="White" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="行间距" Foreground="White" Margin="0,10,0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <Slider x:Name="SliderRowSpacing" Width="200" Minimum="0" Maximum="20" Value="0" ValueChanged="SliderRowSpacing_ValueChanged"/>
                            <TextBlock x:Name="TxtRowSpacing" Text="0" Foreground="White" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Separator Background="#3D3D3D" Margin="0,15"/>

                        <TextBlock Text="帮助链接" Foreground="#888888" FontSize="12" Margin="0,0,0,10"/>
                        <TextBlock Text="GitHub: https://github.com/kasus/lightspeed-UI" Foreground="#6B9FFF" Margin="0,5"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#252525" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button Content="🔄 刷新" Style="{StaticResource SideButtonStyle}" Click="BtnRefresh_Click"/>
                <Button Content="⚙ 设置" Style="{StaticResource SideButtonStyle}" Click="BtnSettings_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
