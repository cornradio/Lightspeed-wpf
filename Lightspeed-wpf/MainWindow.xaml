<Window x:Class="Lightspeed_wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Lightspeed_wpf"
        Title="Lightspeed" 
        Height="800" Width="500"
        Background="#1E1E1E"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        StateChanged="Window_StateChanged"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <Style x:Key="FolderButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5" BorderThickness="2" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5D5D5D"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#569CD3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4D4D4D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SideButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="37"/>
            <Setter Property="Margin" Value="2,2"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5D5D5D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#505050"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D3D3D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ViewToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="0,3,5,3"/>
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5D5D5D"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#3A5A7A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="5,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border Background="{TemplateBinding Background}" 
                                BorderThickness="0" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D2D2D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" 
                                BorderThickness="0" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D2D2D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListViewItem" x:Key="FileListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border Background="{TemplateBinding Background}" 
                                BorderThickness="0" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D2D2D"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#264F78"/>
                </Trigger>
                <DataTrigger Binding="{Binding JustOpened}" Value="True">
                    <Setter Property="Background" Value="#2E7D32"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBoxItem" x:Key="IconListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" 
                                BorderThickness="0" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D2D2D"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#264F78"/>
                </Trigger>
                <DataTrigger Binding="{Binding JustOpened}" Value="True">
                    <Setter Property="Background" Value="#2E7D32"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

       <!-- 1. 滑块样式 (Thumb) -->
<Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="Thumb">
                <!-- 这里的 Background 是滑块本身的颜色 -->
                <Border Background="#4D4D4D" CornerRadius="5" Margin="2,0"/>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>

<!-- 2. 透明的按钮样式 (用于隐藏上下箭头或自定义箭头) -->
<Style x:Key="InvisibleThumbStyle" TargetType="RepeatButton">
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="RepeatButton">
                <Border Background="Transparent" />
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>

<!-- 3. ScrollBar 主样式 -->
<Style TargetType="ScrollBar">
    <Setter Property="Background" Value="#2D2D2D"/>
    <Setter Property="Width" Value="10"/>
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="ScrollBar">
                <Grid x:Name="Bg" Background="{TemplateBinding Background}" SnapsToDevicePixels="true">
                    <!-- Track 是滑行的轨道 -->
                    <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                        <!-- 轨道上方的透明区域 -->
                        <Track.DecreaseRepeatButton>
                            <RepeatButton Style="{StaticResource InvisibleThumbStyle}" Command="{x:Static ScrollBar.PageUpCommand}" />
                        </Track.DecreaseRepeatButton>
                        <!-- 轨道下方的透明区域 -->
                        <Track.IncreaseRepeatButton>
                            <RepeatButton Style="{StaticResource InvisibleThumbStyle}" Command="{x:Static ScrollBar.PageDownCommand}" />
                        </Track.IncreaseRepeatButton>
                        <!-- 中间的滑块 -->
                        <Track.Thumb>
                            <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                        </Track.Thumb>
                    </Track>
                </Grid>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>

        <Style TargetType="ListView">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

<Style TargetType="ContextMenu">
    <Setter Property="Background" Value="#2D2D2D"/>
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="BorderBrush" Value="#4D4D4D"/>
    <Setter Property="BorderThickness" Value="1"/>
    <!-- 关键点 1：消除默认 Padding -->
    <Setter Property="Padding" Value="0"/>
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="ContextMenu">
                <!-- 关键点 2：使用 Border 包装 ItemsPresenter，并绑定背景色 -->
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        SnapsToDevicePixels="True">
                    <ScrollViewer CanContentScroll="True">
                        <!-- 确保内容没有默认 Margin -->
                        <ItemsPresenter Margin="0"/>
                    </ScrollViewer>
                </Border>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#1E1E1E" x:Name="TitleBarGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" Text="Lightspeed" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="Bold"/>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="⚊" Style="{StaticResource TitleBarButtonStyle}" Click="MinimizeButton_Click"/>
                <Button Content="🔳" Style="{StaticResource TitleBarButtonStyle}" Click="MaximizeButton_Click"/>
                <Button Content="✖" Style="{StaticResource CloseButtonStyle}" Click="CloseButton_Click"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Background="#2D2D2D" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="Btn0" Content="0" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn1" Content="1" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn2" Content="2" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn3" Content="3" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn4" Content="4" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn5" Content="5" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn6" Content="6" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn7" Content="7" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn8" Content="8" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn9" Content="9" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" AllowDrop="True" Drop="Grid_Drop" DragOver="Grid_DragOver">
            <ListView x:Name="FileListView" 
                      Background="#1E1E1E" 
                      Foreground="White"
                      BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      MouseDoubleClick="FileListView_MouseDoubleClick"
                      PreviewMouseRightButtonDown="FileListView_MouseRightClick"
                      Visibility="Visible">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem" BasedOn="{StaticResource FileListViewItem}"/>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0" Source="{Binding Icon}" Width="{Binding IconSize}" Height="{Binding IconSize}" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" Foreground="White" Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                            <TextBox x:Name="EditTextBox" Grid.Column="1" VerticalAlignment="Center" Background="#3D3D3D" Foreground="White" BorderThickness="0" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" LostFocus="EditTextBox_LostFocus" PreviewKeyDown="EditTextBox_PreviewKeyDown"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <ListBox x:Name="IconListView" 
                      Background="#1E1E1E" 
                      Foreground="White"
                      BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      MouseDoubleClick="IconListView_MouseDoubleClick"
                      PreviewMouseRightButtonDown="IconListView_MouseRightClick"
                      Visibility="Collapsed">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource IconListBoxItem}">
                        <Setter Property="Width" Value="90"/>
                        <Setter Property="Height" Value="100"/>
                        <Setter Property="Margin" Value="3"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{Binding Icon}" Width="{Binding IconSize}" Height="{Binding IconSize}" Margin="0,0,0,5" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="{Binding Name}" 
                                       TextWrapping="Wrap" 
                                       TextAlignment="Center" 
                                       Foreground="White"
                                       MaxWidth="80"
                                       FontSize="11"
                                       Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                            <TextBox TextWrapping="Wrap" 
                                     TextAlignment="Center" 
                                     Background="#3D3D3D" 
                                     Foreground="White"
                                     MaxWidth="80"
                                     FontSize="11"
                                     BorderThickness="0"
                                     Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                                     LostFocus="EditTextBox_LostFocus"
                                     PreviewKeyDown="EditTextBox_PreviewKeyDown"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border x:Name="SettingsPanel" 
                    Background="#2D2D2D" 
                    Visibility="Collapsed"
                    Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#2D2D2D">
                    <StackPanel>
                        <TextBlock Text="设置" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                        <TextBlock Text="通用设置" Foreground="#888888" FontSize="12" Margin="0,0,0,10"/>
                        <CheckBox x:Name="ChkAutoStartWithWindows" Content="开机自启动" Foreground="White" Margin="0,5" Checked="ChkAutoStartWithWindows_Changed" Unchecked="ChkAutoStartWithWindows_Changed"/>

                        <Separator Background="#3D3D3D" Margin="0,15"/>

                        <TextBlock Text="快捷键设置" Foreground="#888888" FontSize="12" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="当前快捷键: " Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtHotkey" Text="Alt+S" Foreground="#6B9FFF" VerticalAlignment="Center" FontWeight="Bold"/>
                            <Button Content="修改快捷键" Margin="10,0,0,0" Click="BtnCaptureHotkey_Click" Background="#3D3D3D" Foreground="White" BorderThickness="0" Padding="10,5"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkDisableInFullscreen" Content="全屏程序中禁用快捷键" Foreground="White" Margin="0,5" Checked="ChkDisableInFullscreen_Changed" Unchecked="ChkDisableInFullscreen_Changed"/>

                        <Separator Background="#3D3D3D" Margin="0,15"/>

                        <TextBlock Text="AHK 功能" Foreground="#888888" FontSize="12" Margin="0,0,0,10"/>
                        <Button Content="Create Folders" Style="{StaticResource SettingsButtonStyle}" Click="BtnCreateFolders_Click"/>
                        <Button Content="Generate AHK" Style="{StaticResource SettingsButtonStyle}" Click="BtnGenerateAHK_Click"/>
                        <Button Content="Start AHK" Style="{StaticResource SettingsButtonStyle}" Click="BtnStartAHK_Click"/>
                        <Button Content="Generate + Start" Style="{StaticResource SettingsButtonStyle}" Click="BtnGenerateAndStart_Click"/>
                        
                        <CheckBox x:Name="ChkAutoStartAHK" Content="AHK Auto Start" Foreground="White" Margin="0,10,0,5" Checked="ChkAutoStartAHK_Changed" Unchecked="ChkAutoStartAHK_Changed"/>
                        <TextBlock Margin="0,5">
                            <Hyperlink NavigateUri="https://kasusa.lanzoul.com/iClHk28thruj" RequestNavigate="Hyperlink_RequestNavigate">
                                <TextBlock Text="下载 AHK (懒人包)" Foreground="#6B9FFF"/>
                            </Hyperlink>
                        </TextBlock>

                        <Separator Background="#3D3D3D" Margin="0,15"/>

                        <!-- <TextBlock Text="Folder Operations" Foreground="#888888" FontSize="12" Margin="0,0,0,10"/>
                        <Button Content="Open in Explorer" Style="{StaticResource SettingsButtonStyle}" Click="BtnOpenInExplorer_Click"/>

                        <Separator Background="#3D3D3D" Margin="0,15"/> -->

                        <TextBlock Text="Display Settings" Foreground="#888888" FontSize="12" Margin="0,0,0,10"/>
                        <CheckBox x:Name="ChkHideDesktopIni" Content="隐藏 desktop.ini 文件" Foreground="White" Margin="0,5" Checked="ChkHideDesktopIni_Changed" Unchecked="ChkHideDesktopIni_Changed"/>
                        <CheckBox x:Name="ChkHideExtensions" Content="隐藏文件扩展名" Foreground="White" Margin="0,5" Checked="ChkHideExtensions_Changed" Unchecked="ChkHideExtensions_Changed"/>
                        
                        <TextBlock Text="Icon Size (List Mode)" Foreground="White" Margin="0,15,0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <Slider x:Name="SliderIconSize" Width="200" Minimum="16" Maximum="64" Value="30" ValueChanged="SliderIconSize_ValueChanged"/>
                            <TextBlock x:Name="TxtIconSize" Text="30" Foreground="White" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="Icon Size (Icon Mode)" Foreground="White" Margin="0,10,0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <Slider x:Name="SliderIconSizeIcon" Width="200" Minimum="32" Maximum="128" Value="60" ValueChanged="SliderIconSizeIcon_ValueChanged"/>
                            <TextBlock x:Name="TxtIconSizeIcon" Text="60" Foreground="White" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="窗口大小模式" Foreground="White" Margin="0,15,0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <RadioButton x:Name="RbWindowMode0" Content="长条模式" Foreground="White" GroupName="WindowSize" Margin="0,0,15,0" Checked="RbWindowMode_Changed" Tag="0"/>
                            <RadioButton x:Name="RbWindowMode1" Content="宽胖模式" Foreground="White" GroupName="WindowSize" Margin="0,0,15,0" Checked="RbWindowMode_Changed" Tag="1"/>
                            <RadioButton x:Name="RbWindowMode2" Content="自定义" Foreground="White" GroupName="WindowSize" Checked="RbWindowMode_Changed" Tag="2"/>
                        </StackPanel>
                        <StackPanel x:Name="PanelCustomSize" Orientation="Horizontal" Margin="0,5" Visibility="Collapsed">
                            <TextBlock Text="W:" Foreground="White" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtCustomWidth" Width="60" Margin="5,0,10,0" Background="#3D3D3D" Foreground="White" BorderThickness="0" Padding="5,3" TextAlignment="Center" LostFocus="TxtCustomSize_LostFocus"/>
                            <TextBlock Text="H:" Foreground="White" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtCustomHeight" Width="60" Margin="5,0,0,0" Background="#3D3D3D" Foreground="White" BorderThickness="0" Padding="5,3" TextAlignment="Center" LostFocus="TxtCustomSize_LostFocus"/>
                        </StackPanel>

                        <Separator Background="#3D3D3D" Margin="0,15"/>

                        <TextBlock Text="Folder Aliases (数字按钮 0~9 的别名,鼠标悬停时显示)" Foreground="#888888" FontSize="12" Margin="0,0,0,10"/>
                        <UniformGrid Columns="2" Margin="0,5">
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="0:" Foreground="White" Width="20" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBox x:Name="TxtAlias0" Width="160" Margin="5,0,0,0" Background="#3D3D3D" Foreground="White" BorderThickness="0" Padding="5,3" LostFocus="TxtAlias_LostFocus" Tag="0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="1:" Foreground="White" Width="20" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBox x:Name="TxtAlias1" Width="160" Margin="5,0,0,0" Background="#3D3D3D" Foreground="White" BorderThickness="0" Padding="5,3" LostFocus="TxtAlias_LostFocus" Tag="1"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="2:" Foreground="White" Width="20" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBox x:Name="TxtAlias2" Width="160" Margin="5,0,0,0" Background="#3D3D3D" Foreground="White" BorderThickness="0" Padding="5,3" LostFocus="TxtAlias_LostFocus" Tag="2"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="3:" Foreground="White" Width="20" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBox x:Name="TxtAlias3" Width="160" Margin="5,0,0,0" Background="#3D3D3D" Foreground="White" BorderThickness="0" Padding="5,3" LostFocus="TxtAlias_LostFocus" Tag="3"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="4:" Foreground="White" Width="20" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBox x:Name="TxtAlias4" Width="160" Margin="5,0,0,0" Background="#3D3D3D" Foreground="White" BorderThickness="0" Padding="5,3" LostFocus="TxtAlias_LostFocus" Tag="4"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="5:" Foreground="White" Width="20" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBox x:Name="TxtAlias5" Width="160" Margin="5,0,0,0" Background="#3D3D3D" Foreground="White" BorderThickness="0" Padding="5,3" LostFocus="TxtAlias_LostFocus" Tag="5"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="6:" Foreground="White" Width="20" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBox x:Name="TxtAlias6" Width="160" Margin="5,0,0,0" Background="#3D3D3D" Foreground="White" BorderThickness="0" Padding="5,3" LostFocus="TxtAlias_LostFocus" Tag="6"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="7:" Foreground="White" Width="20" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBox x:Name="TxtAlias7" Width="160" Margin="5,0,0,0" Background="#3D3D3D" Foreground="White" BorderThickness="0" Padding="5,3" LostFocus="TxtAlias_LostFocus" Tag="7"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="8:" Foreground="White" Width="20" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBox x:Name="TxtAlias8" Width="160" Margin="5,0,0,0" Background="#3D3D3D" Foreground="White" BorderThickness="0" Padding="5,3" LostFocus="TxtAlias_LostFocus" Tag="8"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="9:" Foreground="White" Width="20" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBox x:Name="TxtAlias9" Width="160" Margin="5,0,0,0" Background="#3D3D3D" Foreground="White" BorderThickness="0" Padding="5,3" LostFocus="TxtAlias_LostFocus" Tag="9"/>
                            </StackPanel>
                        </UniformGrid>
                        <TextBlock Text="提示: 别名仅保存在配置文件中,不会修改文件夹名。留空则悬停时显示文件夹实际名称。" Foreground="#666666" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>

                        <Separator Background="#3D3D3D" Margin="0,15"/>

                        <TextBlock Text="Help Links" Foreground="#888888" FontSize="12" Margin="0,0,0,10"/>
                        <TextBlock Margin="0,5">
                            <Hyperlink NavigateUri="https://lightspeed.cornradio.org/" RequestNavigate="Hyperlink_RequestNavigate">
                                <TextBlock Text="https://lightspeed.cornradio.org/" Foreground="#6B9FFF"/>
                            </Hyperlink>
                        </TextBlock>

                        <Separator Background="#3D3D3D" Margin="0,15"/>

                        <TextBlock Text="关于" Foreground="#888888" FontSize="12" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="当前版本: " Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtVersion" Text="-" Foreground="#6B9FFF" VerticalAlignment="Center" FontWeight="Bold"/>
                            <Button Content="检查更新" Margin="10,0,0,0" Click="BtnCheckUpdate_Click" Background="#3D3D3D" Foreground="White" BorderThickness="0" Padding="10,5"/>
                            <TextBlock x:Name="TxtUpdateStatus" Text="" Foreground="#888888" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#252525" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="📁" Style="{StaticResource SideButtonStyle}" Click="BtnOpenInExplorer_Click" />
                    <Button Content="⭯" Style="{StaticResource SideButtonStyle}" Click="BtnRefresh_Click"/>
                    <Button Content="⚡" Style="{StaticResource SideButtonStyle}" Click="BtnQuickStartAHK_Click" ToolTip="Generate and Start AHK (No Dialog)"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ToggleButton x:Name="BtnListView" Content="L" Style="{StaticResource ViewToggleButtonStyle}" IsChecked="True" Click="BtnListView_Click"/>
                    <ToggleButton x:Name="BtnIconView" Content="G" Style="{StaticResource ViewToggleButtonStyle}" IsChecked="False" Click="BtnIconView_Click"/>
                    <ToggleButton x:Name="BtnSettings" Content="⋮" Click="BtnSettings_Click" Height="37" Margin="2,2" Background="#3D3D3D" Foreground="White" BorderThickness="0">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5" Padding="15,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#5D5D5D"/>
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#569CD3"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 顶部居中弹出:显示当前 hover 的数字按钮对应的别名 -->
        <Popup x:Name="AliasPopup"
               Placement="Top"
               PlacementTarget="{Binding ElementName=TitleBarGrid}"
               HorizontalOffset="0"
               VerticalOffset="-8"
               AllowsTransparency="True"
               IsOpen="False">
            <Border Background="#2D2D2D"
                    BorderBrush="#569CD3"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,6"
                    MaxWidth="400">
                <TextBlock x:Name="TxtAliasOverlay"
                           Text=""
                           Foreground="White"
                           FontSize="13"
                           FontWeight="Bold"
                           TextWrapping="Wrap"/>
            </Border>
        </Popup>

        <!-- Toast 通知:浮在底部栏之上, 不拦截鼠标事件 -->
        <Grid Grid.Row="0" Grid.RowSpan="4"
              HorizontalAlignment="Center"
              VerticalAlignment="Bottom"
              Margin="0,0,0,70"
              IsHitTestVisible="False">
            <Border x:Name="ToastBar"
                    Background="#E62D2D2D"
                    BorderBrush="#569CD3"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="24,10"
                    Visibility="Collapsed"
                    Opacity="0">
                <TextBlock x:Name="ToastText"
                           Foreground="White"
                           FontSize="13"
                           FontWeight="SemiBold"/>
            </Border>
        </Grid>
    </Grid>
</Window>
