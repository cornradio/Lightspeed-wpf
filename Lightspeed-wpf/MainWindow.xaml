<Window x:Class="Lightspeed_wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lightspeed" 
        Height="600" Width="450"
        Background="#1E1E1E"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="FolderButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5D5D5D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SideButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5D5D5D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border Background="{TemplateBinding Background}" 
                                BorderThickness="0" 
                                Padding="5">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D2D2D"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3D3D3D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D2D2D" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="Btn0" Content="0" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn1" Content="1" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn2" Content="2" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn3" Content="3" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn4" Content="4" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn5" Content="5" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn6" Content="6" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn7" Content="7" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn8" Content="8" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
                <Button x:Name="Btn9" Content="9" Style="{StaticResource FolderButtonStyle}" Click="FolderButton_Click"/>
            </StackPanel>
        </Border>

        <ListView Grid.Row="1" x:Name="FileListView" 
                  Background="#1E1E1E" 
                  Foreground="White"
                  BorderThickness="0"
                  MouseDoubleClick="FileListView_MouseDoubleClick"
                  MouseRightButtonDown="FileListView_MouseRightClick">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <Image Source="{Binding Icon}" Width="24" Height="24" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Border Grid.Row="2" Background="#252525" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button Content="刷新" Style="{StaticResource SideButtonStyle}" Click="BtnRefresh_Click"/>
                <Button Content="设置" Style="{StaticResource SideButtonStyle}" Click="BtnSettings_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
